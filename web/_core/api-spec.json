{
  "openapi": "3.0.3",
  "info": {
    "title": "WebMS Intra REST API",
    "description": "Internal portal platform REST API. All endpoints require an authenticated portal session (cookie-based) and a valid CSRF token on write operations (passed via `X-CSRF-TOKEN` header or `csrf_token` body field). Every endpoint can be enabled/disabled per-site via the `api.{module}.{action}.enabled` setting.",
    "version": "1.0.0",
    "license": {
      "name": "All Rights Reserved",
      "url": "https://github.com/MWBMPartners/WebMS-Intra"
    },
    "contact": {
      "name": "MWBM Partners Ltd (t/a MWservices)",
      "url": "https://github.com/MWBMPartners/WebMS-Intra"
    }
  },
  "servers": [
    {
      "url": "/",
      "description": "Same-origin (whichever portal is serving this page)"
    }
  ],
  "security": [
    {
      "sessionCookie": [],
      "csrfToken": []
    }
  ],
  "tags": [
    {
      "name": "Events",
      "description": "Events / calendar entries"
    },
    {
      "name": "Attendance",
      "description": "Headcount sessions"
    },
    {
      "name": "Announcements",
      "description": "Per-site noticeboard"
    },
    {
      "name": "Leadership",
      "description": "Roles + assignments"
    },
    {
      "name": "Tasks",
      "description": "Reminders / tasks"
    },
    {
      "name": "Prayer Requests",
      "description": "Prayer requests (visibility-aware)"
    },
    {
      "name": "Documents",
      "description": "Document library"
    },
    {
      "name": "Noticeboard",
      "description": "Visual poster wall (Canva embeds, image/video/text posters)"
    },
    {
      "name": "Users",
      "description": "User directory (admin only)"
    }
  ],
  "components": {
    "securitySchemes": {
      "sessionCookie": {
        "type": "apiKey",
        "in": "cookie",
        "name": "PHPSESSID",
        "description": "Portal session cookie set on sign-in."
      },
      "csrfToken": {
        "type": "apiKey",
        "in": "header",
        "name": "X-CSRF-TOKEN",
        "description": "CSRF token. Read from `<meta name=\"csrf-token\">` in the portal HTML or from the session. Required on POST endpoints; ignored on read-only GETs."
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "required": [
          "status",
          "message"
        ],
        "properties": {
          "status": {
            "type": "string",
            "example": "error"
          },
          "message": {
            "type": "string",
            "example": "Forbidden"
          },
          "detail": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "PaginatedListResponse": {
        "type": "object",
        "required": [
          "status",
          "data"
        ],
        "properties": {
          "status": {
            "type": "string",
            "example": "success"
          },
          "data": {
            "type": "object",
            "properties": {
              "count": {
                "type": "integer",
                "example": 12
              },
              "page": {
                "type": "integer",
                "example": 1
              },
              "limit": {
                "type": "integer",
                "example": 20
              },
              "totalItems": {
                "type": "integer",
                "example": 142
              },
              "totalPages": {
                "type": "integer",
                "example": 8
              },
              "items": {
                "type": "array",
                "items": {
                  "type": "object"
                }
              }
            }
          }
        }
      },
      "Event": {
        "type": "object",
        "properties": {
          "eventID": {
            "type": "integer",
            "example": 1234
          },
          "eventName": {
            "type": "string",
            "example": "Sunday Service"
          },
          "eventSlug": {
            "type": "string",
            "example": "sunday-service"
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "startDateTime": {
            "type": "string",
            "format": "date-time"
          },
          "endDateTime": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "timezone": {
            "type": "string",
            "example": "Europe/London",
            "nullable": true
          },
          "isAllDay": {
            "type": "integer",
            "enum": [
              0,
              1
            ]
          },
          "locationName": {
            "type": "string",
            "nullable": true
          },
          "status": {
            "type": "string",
            "enum": [
              "draft",
              "published",
              "cancelled",
              "archived"
            ]
          },
          "isPublic": {
            "type": "integer",
            "enum": [
              0,
              1
            ]
          },
          "isFeatured": {
            "type": "integer",
            "enum": [
              0,
              1
            ]
          },
          "categoryName": {
            "type": "string",
            "nullable": true
          },
          "typeName": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "EventCreate": {
        "type": "object",
        "required": [
          "eventName",
          "startDateTime"
        ],
        "properties": {
          "eventName": {
            "type": "string",
            "example": "Worship Service"
          },
          "startDateTime": {
            "type": "string",
            "format": "date-time",
            "example": "2026-06-01T10:00:00"
          },
          "endDateTime": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "isAllDay": {
            "type": "boolean",
            "default": false
          },
          "locationName": {
            "type": "string",
            "nullable": true
          },
          "categoryID": {
            "type": "integer",
            "nullable": true
          },
          "typeID": {
            "type": "integer",
            "nullable": true
          },
          "status": {
            "type": "string",
            "enum": [
              "draft",
              "published",
              "cancelled",
              "archived"
            ],
            "default": "draft"
          },
          "isPublic": {
            "type": "boolean",
            "default": true
          },
          "isFeatured": {
            "type": "boolean",
            "default": false
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "csrf_token": {
            "type": "string",
            "description": "CSRF token (or use X-CSRF-TOKEN header)"
          }
        }
      },
      "NoticeboardPoster": {
        "type": "object",
        "description": "Poster as returned by GET /api/noticeboard/list (DB columns already mapped to the field names the board component reads).",
        "properties": {
          "id": {
            "type": "string",
            "example": "p42",
            "description": "Client-facing id; the literal string \"p\" + posterID."
          },
          "title": {
            "type": "string"
          },
          "kicker": {
            "type": "string",
            "description": "Short eyebrow line shown above the title."
          },
          "category": {
            "type": "string",
            "example": "Community"
          },
          "schedule": {
            "type": "string",
            "enum": [
              "once",
              "weekly"
            ]
          },
          "date": {
            "type": "string",
            "format": "date",
            "description": "Set when schedule=once; empty string otherwise."
          },
          "weekday": {
            "type": "integer",
            "nullable": true,
            "description": "0=Sunday … 6=Saturday. Set when schedule=weekly, otherwise null."
          },
          "time": {
            "type": "string",
            "example": "19:30",
            "description": "24-hour HH:MM, or empty string if not set."
          },
          "location": {
            "type": "string"
          },
          "link": {
            "type": "string",
            "description": "Official event page. The board opens this when the enlarged poster is tapped a second time."
          },
          "mediaType": {
            "type": "string",
            "enum": [
              "image",
              "video",
              "canva"
            ],
            "description": "Text-only posters (no image/canva) are reported here as \"image\" with an empty image URL."
          },
          "image": {
            "type": "string",
            "description": "Media URL, for mediaType image|video."
          },
          "canva": {
            "type": "string",
            "description": "Canva embed URL, for mediaType canva."
          },
          "thumb": {
            "type": "string",
            "description": "Optional board thumbnail override for Canva posters."
          },
          "colorIndex": {
            "type": "integer",
            "example": 0,
            "description": "Index into the board's built-in accent-colour palette."
          },
          "aspect": {
            "type": "string",
            "example": "4/5",
            "description": "Poster tile aspect ratio, e.g. \"4/5\", \"3/4\", \"1/1\"."
          },
          "serif": {
            "type": "boolean",
            "description": "true = editorial serif title font, false = bold sans-serif."
          }
        }
      },
      "PosterInput": {
        "type": "object",
        "description": "One poster in the `posters` array sent to POST /api/noticeboard/save. The client always sends the FULL desired board state — any existing poster whose id is missing from the array is soft-deleted.",
        "required": [
          "title"
        ],
        "properties": {
          "id": {
            "type": "string",
            "example": "p42",
            "description": "Pass the existing \"p<posterID>\" to update that poster. Omit, or use a fresh client-generated id (e.g. \"p<timestamp>\"), to insert a new one — an id that doesn't belong to this site is treated as new rather than overwriting another site's poster."
          },
          "title": {
            "type": "string",
            "description": "Required — rows with an empty/whitespace-only title are silently skipped."
          },
          "kicker": {
            "type": "string"
          },
          "category": {
            "type": "string",
            "default": "Other"
          },
          "schedule": {
            "type": "string",
            "enum": [
              "once",
              "weekly"
            ],
            "default": "once"
          },
          "date": {
            "type": "string",
            "format": "date",
            "description": "Used when schedule=once."
          },
          "weekday": {
            "type": "integer",
            "minimum": 0,
            "maximum": 6,
            "description": "Used when schedule=weekly (0=Sunday … 6=Saturday)."
          },
          "time": {
            "type": "string",
            "example": "19:30"
          },
          "location": {
            "type": "string"
          },
          "link": {
            "type": "string",
            "description": "http(s):// absolute or a root-relative (\"/…\") path only — any other scheme (e.g. javascript:) is silently stripped to empty."
          },
          "mediaType": {
            "type": "string",
            "enum": [
              "image",
              "video"
            ],
            "description": "Server-side derived value wins: forced to \"canva\" if canva is set, or \"text\" if neither canva nor image is set."
          },
          "image": {
            "type": "string",
            "description": "Media URL for image/video posters. data: URIs are rejected with 422 — upload via the media library and pass its URL instead."
          },
          "canva": {
            "type": "string",
            "description": "Canva embed/share URL. Must start with https://www.canva.com/ or it is discarded."
          },
          "thumb": {
            "type": "string"
          },
          "colorIndex": {
            "type": "integer",
            "default": 0
          },
          "aspect": {
            "type": "string",
            "default": "4/5"
          },
          "serif": {
            "type": "boolean",
            "default": false
          }
        }
      }
    }
  },
  "paths": {
    "/api/events/list": {
      "get": {
        "tags": [
          "Events"
        ],
        "summary": "List published events for the current site",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "default": 1
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedListResponse"
                }
              }
            }
          },
          "401": {
            "description": "Auth required",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "Endpoint disabled"
          }
        }
      }
    },
    "/api/events/detail": {
      "get": {
        "tags": [
          "Events"
        ],
        "summary": "Fetch a single event by ID or slug",
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "slug",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Event"
                }
              }
            }
          },
          "404": {
            "description": "Not found"
          }
        }
      }
    },
    "/api/events/create": {
      "post": {
        "tags": [
          "Events"
        ],
        "summary": "Create a new event (admin only)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EventCreate"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created"
          },
          "400": {
            "description": "Validation error"
          },
          "403": {
            "description": "Admin required or CSRF failed"
          }
        }
      }
    },
    "/api/events/update": {
      "post": {
        "tags": [
          "Events"
        ],
        "summary": "Update event fields (PATCH-style; only present fields are touched)",
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Or pass eventID in body"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "description": "Subset of EventCreate fields + eventID"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Validation error"
          },
          "404": {
            "description": "Event not found"
          }
        }
      }
    },
    "/api/events/delete": {
      "post": {
        "tags": [
          "Events"
        ],
        "summary": "Soft-delete an event (isDeleted = 1)",
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Or pass eventID in body"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "404": {
            "description": "Event not found or already deleted"
          }
        }
      }
    },
    "/api/attendance/list": {
      "get": {
        "tags": [
          "Attendance"
        ],
        "summary": "List attendance sessions for the current site",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/announcements/list": {
      "get": {
        "tags": [
          "Announcements"
        ],
        "summary": "List active announcements for the current site",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/noticeboard/list": {
      "get": {
        "tags": [
          "Noticeboard"
        ],
        "summary": "List active posters on the current site's noticeboard",
        "description": "Any authenticated user may read. Returns every non-deleted poster for the current site, ordered by manual sort order then event date.",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/NoticeboardPoster"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Auth required",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "Endpoint disabled"
          }
        }
      }
    },
    "/api/noticeboard/qr": {
      "get": {
        "tags": [
          "Noticeboard"
        ],
        "summary": "Render a QR code image for a noticeboard share link",
        "description": "Any authenticated user may read. `data` must be this site's own host if it includes a scheme — the endpoint refuses to act as an open QR redirector for arbitrary third-party URLs.",
        "parameters": [
          {
            "name": "data",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "maxLength": 300
            },
            "description": "Text or URL to encode. Must resolve to this same host when it contains a scheme (e.g. https://…)."
          }
        ],
        "responses": {
          "200": {
            "description": "QR image — PNG when the gd extension is available, SVG fallback otherwise (Content-Type reflects the actual format returned).",
            "content": {
              "image/png": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              },
              "image/svg+xml": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "401": {
            "description": "Auth required"
          },
          "403": {
            "description": "Endpoint disabled"
          },
          "422": {
            "description": "Missing/oversized data parameter, or data does not resolve to this host"
          }
        }
      }
    },
    "/api/noticeboard/save": {
      "post": {
        "tags": [
          "Noticeboard"
        ],
        "summary": "Replace the current site's poster set (site admins only)",
        "description": "Site admins only (App::isSiteAdmin()) — CSRF-protected via the X-CSRF-TOKEN header. The client sends the FULL desired poster array in one call; posters upsert by their \"p<posterID>\" id (a foreign or new-looking id inserts a fresh row instead of overwriting another tenant's poster), and any existing poster left out of the array is soft-deleted. The whole batch is validated before any row is written, and rolled back together on failure.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "posters"
                ],
                "properties": {
                  "posters": {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/PosterInput"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Saved",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "ok"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "saved": {
                          "type": "boolean",
                          "example": true
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid CSRF token"
          },
          "403": {
            "description": "Admin access required, or endpoint disabled"
          },
          "422": {
            "description": "Malformed payload — missing `posters` array, or a poster's image is a data: URI (upload via the media library instead)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Save failed — the whole batch was rolled back",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/leadership/list": {
      "get": {
        "tags": [
          "Leadership"
        ],
        "summary": "List leadership roles and current assignees",
        "parameters": [
          {
            "name": "role",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Optional roleID filter"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/tasks/list": {
      "get": {
        "tags": [
          "Tasks"
        ],
        "summary": "List tasks (own by default; admins can filter via userID)",
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "open",
                "completed",
                "all"
              ],
              "default": "open"
            }
          },
          {
            "name": "userID",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Admin-only filter"
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/prayer-requests/list": {
      "get": {
        "tags": [
          "Prayer Requests"
        ],
        "summary": "List prayer requests visible to the current user",
        "description": "Non-admins see their own requests plus congregation-visible ones. Admins see all. Anonymous-flagged requests have `submitterID` nulled for non-admin readers.",
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "pending",
                "active",
                "answered",
                "archived",
                "all"
              ],
              "default": "active"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/documents/list": {
      "get": {
        "tags": [
          "Documents"
        ],
        "summary": "List documents for the current site",
        "parameters": [
          {
            "name": "categoryID",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/users/list": {
      "get": {
        "tags": [
          "Users"
        ],
        "summary": "List users (admin only)",
        "responses": {
          "200": {
            "description": "OK"
          },
          "403": {
            "description": "Admin required"
