# =============================================================================
# WebMS Intra - .gitignore
# =============================================================================

# OS files
.DS_Store
Thumbs.db

# IDE / editor
.idea/
.vscode/
*.swp
*.swo
*~

# Claude auto-memory symlink (local machine path, not portable)
.claude/MEMORY.md

# Secrets and credentials (NEVER commit these)
web/_auth_keys/
.env
*.key

# User uploads (server-managed, not committed)
web/_uploads/

# Backups (server-managed, not committed)
web/_backups/

# Self-hosted libraries (manually uploaded to server, not committed)
# dompdf etc. go in web/_libraries/ on the server
web/_libraries/

# Local asset fallbacks (downloaded from CDNs, placed locally for fallback)
web/public_html/assets/css/bootstrap.min.css
web/public_html/assets/js/bootstrap.bundle.min.js
web/public_html/assets/css/fontawesome-all.min.css
web/public_html/assets/webfonts/

# Vendor libraries that should be manually managed
# (web/vendor/simplejwt/ IS committed as it's our own code)

# Logs
*.log
error_log

# PHP
*.php.bak
